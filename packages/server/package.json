{
    "name": "@buildmind/server",
    "type": "module",
    "private": true,
    "exports": {
        ".": "./src/index.ts"
    },
    "scripts": {
        "dev": "bun run --hot src/index.ts",
        "build": "bun build src/index.ts --outdir dist --target bun",
        "postinstall": "bun run --cwd ../database db:generate"
    },
    "dependencies": {
        "@ai-sdk/anthropic": "^4.0.8",
        "@ai-sdk/google": "^4.0.8",
        "@ai-sdk/openai": "^4.0.8",
        "@buildmind/database": "workspace:*",
        "@buildmind/shared": "workspace:*",
        "@hono/zod-validator": "^0.8.0",
        "ai": "^7.0.15",
        "dotenv": "^17.4.2",
        "hono": "^4.12.27",
        "zod": "^4.4.3"
    },
    "devDependencies": {
        "@types/bun": "^1.3.14"
    }
}